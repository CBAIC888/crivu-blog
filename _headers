/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: geolocation=(), microphone=(), camera=()
  X-Frame-Options: DENY
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

/
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self'; style-src 'self'; connect-src 'self'

/index.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self'; style-src 'self'; connect-src 'self'

/about.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self'; style-src 'self'; connect-src 'self'

/articles.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self'; style-src 'self'; connect-src 'self'

/category.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self'; style-src 'self'; connect-src 'self'

/issues-x.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self'; style-src 'self'; connect-src 'self'

/issues.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self'; style-src 'self'; connect-src 'self'

/post.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self'; style-src 'self'; connect-src 'self'

/tag.html
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https:; script-src 'self'; style-src 'self'; connect-src 'self'

/*.html
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/admin/*
  Content-Security-Policy: default-src 'self'; base-uri 'self'; frame-ancestors 'none'; img-src 'self' data: https: blob:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.github.com https://github.com; form-action 'self'

/api/auth
  Content-Security-Policy: default-src 'none'; base-uri 'none'; frame-ancestors 'none'; img-src 'none'; script-src 'none'; style-src 'none'; connect-src 'none'; form-action 'none'

/api/r2-upload-sign
  Content-Security-Policy: default-src 'none'; base-uri 'none'; frame-ancestors 'none'; img-src 'none'; script-src 'none'; style-src 'none'; connect-src 'none'; form-action 'none'

/api/callback
  Content-Security-Policy: default-src 'none'; base-uri 'none'; frame-ancestors 'none'; img-src 'none'; script-src 'unsafe-inline'; style-src 'none'; connect-src 'none'; form-action 'none'

/admin/config.yml
  Cache-Control: no-store, no-cache, must-revalidate, max-age=0

/admin/*
  Cache-Control: no-cache, max-age=0

/assets/*
  Cache-Control: public, max-age=31536000, immutable

/posts/*
  Cache-Control: public, max-age=120, s-maxage=600, stale-while-revalidate=86400
